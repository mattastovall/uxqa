{
  "name": "uxqa",
  "version": "0.0.0",
  "description": "Calibrated device and browser simulation for React applications.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattastovall/uxqa.git"
  },
  "homepage": "https://github.com/mattastovall/uxqa#readme",
  "bugs": {
    "url": "https://github.com/mattastovall/uxqa/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "workspaces": ["demo"],
  "scripts": {
    "build": "tsup",
    "check": "npm run lint && npm run typecheck && npm test -- --run && npm run build && npm run verify:package",
    "demo:build": "npm run build && npm run build --workspace demo",
    "demo:dev": "npm run build && npm run dev --workspace demo",
    "lint": "eslint .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "verify:package": "node scripts/verify-package.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.30.1",
    "jsdom": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
